												},
												"formatSettings": {
													"type": "DelimitedTextWriteSettings",
													"quoteAllText": true,
													"fileExtension": ".txt"
												}
											},
											"enableStaging": false,
											"translator": {
												"value": "@if(\n    equals(item().name,'DimPassenger.csv'),pipeline().parameters.passenger_schema,pipeline().parameters.flight_schema\n)",
												"type": "Expression"
											}
										},
										"inputs": [
											{
												"referenceName": "GetAllDataWithParameter",
												"type": "DatasetReference",
												"parameters": {
													"current_file": {
														"value": "@item().name",
														"type": "Expression"
													}
												}
											}
										],
										"outputs": [
											{
												"referenceName": "SchemaSink",
												"type": "DatasetReference",
												"parameters": {
													"current_file_name": {
														"value": "@item().name",
														"type": "Expression"
													}
												}
											}
										]
									}
								]
							}
						}
					]
				}
			}
