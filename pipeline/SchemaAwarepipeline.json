								"expression": {
									"value": "@if(or(equals(item().name,'DimPassenger.csv'),equals(item().name,'DimFlight.csv')), true, false)",
									"type": "Expression"
								},
								"ifTrueActivities": [
									{
										"name": "SchemaAwareCopy",
										"type": "Copy",
