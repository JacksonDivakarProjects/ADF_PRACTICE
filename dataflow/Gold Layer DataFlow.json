{
	"name": "Gold Layer DataFlow",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"linkedService": {
						"referenceName": "JacksonAzureStorage",
						"type": "LinkedServiceReference"
					},
					"name": "Airline"
				},
				{
					"linkedService": {
						"referenceName": "JacksonAzureStorage",
						"type": "LinkedServiceReference"
					},
					"name": "Flight"
				},
				{
					"linkedService": {
						"referenceName": "JacksonAzureStorage",
						"type": "LinkedServiceReference"
					},
					"name": "FactBookings"
				},
				{
					"linkedService": {
						"referenceName": "JacksonAzureStorage",
						"type": "LinkedServiceReference"
					},
					"name": "Passenger"
				},
				{
					"linkedService": {
						"referenceName": "JacksonAzureStorage",
						"type": "LinkedServiceReference"
					},
					"name": "Airport"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "JacksonAzureStorage",
						"type": "LinkedServiceReference"
					},
					"name": "OBT"
				}
			],
			"transformations": [
				{
					"name": "RenamingAirport"
				},
				{
					"name": "RenamingPassenger"
				},
				{
					"name": "PassengerJoin"
				},
				{
					"name": "AirlineJoin"
				},
				{
					"name": "RemovePassengerID"
				},
				{
					"name": "RemoveAirlineID"
				},
				{
					"name": "OriginAirportID"
				},
				{
					"name": "CastedAirport"
				},
				{
					"name": "RemoveOriginAirport"
				},
				{
					"name": "DestinationAirportID"
				},
				{
					"name": "RemoveDestinationAirport"
				},
				{
					"name": "FlightJoin"
				},
				{
					"name": "RemoveFlight"
				},
				{
					"name": "InsertData"
				}
			],
			"scriptLines": [
				"source(output(",
				"          airline_id as short,",
				"          airline_name as string,",
				"          country as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'delta',",
				"     fileSystem: 'sinkpractice',",
				"     folderPath: 'SILVER_LAYER/Airline') ~> Airline",
				"source(output(",
				"          flight_id as short,",
				"          flight_number as string,",
				"          departure_time as string,",
				"          arrival_time as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'delta',",
				"     fileSystem: 'sinkpractice',",
				"     folderPath: 'SILVER_LAYER/Flight') ~> Flight",
				"source(output(",
				"          booking_id as integer,",
				"          passenger_id as integer,",
				"          flight_id as integer,",
				"          airline_id as integer,",
				"          origin_airport_id as integer,",
				"          destination_airport_id as integer,",
				"          booking_date as date,",
				"          ticket_cost as decimal(10,2),",
				"          flight_duration_mins as integer,",
				"          checkin_status as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'delta',",
				"     fileSystem: 'sinkpractice',",
				"     folderPath: 'SILVER_LAYER/FactBookings') ~> FactBookings",
				"source(output(",
				"          passenger_id as short,",
				"          full_name as string,",
				"          gender as string,",
				"          age as short",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'delta',",
				"     fileSystem: 'sinkpractice',",
				"     folderPath: 'SILVER_LAYER/Passenger') ~> Passenger",
				"source(output(",
				"          airport_id as string,",
				"          airport_name as string,",
				"          city as string,",
				"          country as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'delta',",
				"     fileSystem: 'sinkpractice',",
				"     folderPath: 'SILVER_LAYER/Airport') ~> Airport",
				"Airport select(mapColumn(",
				"          airport_id,",
				"          airport_name,",
				"          airport_city = city,",
				"          airport_country = country",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> RenamingAirport",
				"Passenger select(mapColumn(",
				"          passenger_id,",
				"          passenger_full_name = full_name,",
				"          passenger_gender = gender,",
				"          passenger_age = age",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> RenamingPassenger",
				"FactBookings, RenamingPassenger join(FactBookings@passenger_id == RenamingPassenger@passenger_id,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> PassengerJoin",
				"RemovePassengerID, Airline join(RemovePassengerID@airline_id == Airline@airline_id,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> AirlineJoin",
				"PassengerJoin select(mapColumn(",
				"          booking_id,",
				"          passenger_id = FactBookings@passenger_id,",
				"          flight_id,",
				"          airline_id,",
				"          origin_airport_id,",
				"          destination_airport_id,",
				"          booking_date,",
				"          ticket_cost,",
				"          flight_duration_mins,",
				"          checkin_status,",
				"          passenger_full_name,",
				"          passenger_gender,",
				"          passenger_age",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> RemovePassengerID",
				"AirlineJoin select(mapColumn(",
				"          booking_id,",
				"          passenger_id,",
				"          flight_id,",
				"          airline_id = RemovePassengerID@airline_id,",
				"          origin_airport_id,",
				"          destination_airport_id,",
				"          booking_date,",
				"          ticket_cost,",
				"          flight_duration_mins,",
				"          checkin_status,",
				"          passenger_full_name,",
				"          passenger_gender,",
				"          passenger_age,",
				"          airline_name,",
				"          country",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> RemoveAirlineID",
				"RemoveAirlineID, CastedAirport join(origin_airport_id == airport_id,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> OriginAirportID",
				"RenamingAirport cast(output(",
				"          airport_id as integer",
				"     ),",
				"     errors: true) ~> CastedAirport",
				"OriginAirportID select(mapColumn(",
				"          booking_id,",
				"          passenger_id,",
				"          flight_id,",
				"          airline_id,",
				"          origin_airport_id,",
				"          destination_airport_id,",
				"          booking_date,",
				"          ticket_cost,",
				"          flight_duration_mins,",
				"          checkin_status,",
				"          passenger_full_name,",
				"          passenger_gender,",
				"          passenger_age,",
				"          airline_name,",
				"          country,",
				"          origin_airport_name = airport_name,",
				"          origin_airport_city = airport_city,",
				"          origin_airport_country = airport_country",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> RemoveOriginAirport",
				"RemoveOriginAirport, CastedAirport join(destination_airport_id == airport_id,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> DestinationAirportID",
				"DestinationAirportID select(mapColumn(",
				"          booking_id,",
				"          passenger_id,",
				"          flight_id,",
				"          airline_id,",
				"          origin_airport_id,",
				"          destination_airport_id,",
				"          booking_date,",
				"          ticket_cost,",
				"          flight_duration_mins,",
				"          checkin_status,",
				"          passenger_full_name,",
				"          passenger_gender,",
				"          passenger_age,",
				"          airline_name,",
				"          country,",
				"          origin_airport_name,",
				"          origin_airport_city,",
				"          origin_airport_country,",
				"          destination_airport_name = airport_name,",
				"          destination_airport_city = airport_city,",
				"          destination_airport_country = airport_country",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> RemoveDestinationAirport",
				"RemoveDestinationAirport, Flight join(RemoveDestinationAirport@flight_id == Flight@flight_id,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> FlightJoin",
				"FlightJoin select(mapColumn(",
				"          booking_id,",
				"          passenger_id,",
				"          flight_id = RemoveDestinationAirport@flight_id,",
				"          airline_id,",
				"          origin_airport_id,",
				"          destination_airport_id,",
				"          booking_date,",
				"          ticket_cost,",
				"          flight_duration_mins,",
				"          checkin_status,",
				"          passenger_full_name,",
				"          passenger_gender,",
				"          passenger_age,",
				"          airline_name,",
				"          country,",
				"          origin_airport_name,",
				"          origin_airport_city,",
				"          origin_airport_country,",
				"          destination_airport_name,",
				"          destination_airport_city,",
				"          destination_airport_country,",
				"          flight_number,",
				"          departure_time,",
				"          arrival_time",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> RemoveFlight",
				"RemoveFlight alterRow(insertIf(1==1)) ~> InsertData",
				"InsertData sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'delta',",
				"     fileSystem: 'sinkpractice',",
				"     folderPath: 'GOLD_LAYER/OBT',",
				"     overwrite: true,",
				"     mergeSchema: false,",
				"     autoCompact: false,",
				"     optimizedWrite: false,",
				"     vacuum: 0,",
				"     deletable: false,",
				"     insertable: true,",
				"     updateable: false,",
				"     upsertable: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> OBT"
			]
		}
	}
}